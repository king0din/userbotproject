# ============================================
# KingTG UserBot Service - Ortam Değişkenleri
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#     cp .env.example .env
# .env dosyası ASLA git'e commit'lenmemeli (bkz. .gitignore).
# ============================================

# Telegram API Bilgileri (https://my.telegram.org adresinden alın)
API_ID=12345678
API_HASH=buraya_api_hash

# Bot Token (@BotFather'dan alın)
BOT_TOKEN=buraya_bot_token
BOT_USERNAME=KingUser_bot

# Bot Sahibi Bilgileri
OWNER_ID=123456789
OWNER_USERNAME=kullanici_adiniz

# MongoDB Bağlantı Dizesi (Atlas panelinden kendi bilginizi girin)
# Örn: mongodb+srv://<kullanici>:<sifre>@<cluster>.mongodb.net/?appName=Cluster0
MONGO_URI=mongodb+srv://KULLANICI:SIFRE@CLUSTER.mongodb.net/?appName=Cluster0
MONGO_DB_NAME=kingtg_userbot

# Log Kanalı/Grubu ID'si (Opsiyonel ama önerilir)
# Grup/Kanal için: -100XXXXXXXXXX
LOG_CHANNEL=-100123456789

# GitHub Repo (Güncelleme için)
GITHUB_REPO=https://github.com/KullaniciAdi/repo_adi
